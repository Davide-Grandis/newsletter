name = "newsletter-cleanup"
main = "src/index.ts"
compatibility_date = "2025-01-15"

# RETENTION_DAYS resolves from the D1 `settings` table, falling back to the
# built-in default in shared/settings.ts.

[[d1_databases]]
binding = "DB"
database_name = "newsletter_db"
database_id = "REPLACE_WITH_D1_ID"

[[r2_buckets]]
binding = "ARCHIVE"
bucket_name = "newsletter-archive"

# Runs once daily at 04:00 UTC to purge campaigns older than RETENTION_DAYS.
[triggers]
crons = ["0 4 * * *"]
